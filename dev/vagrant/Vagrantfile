# -*- mode: ruby -*-
# nanofuse dev/test VM - Ubuntu 24.04 with nested KVM + Firecracker
#
# Gives automation full sudo in a disposable VM to:
#   - Build nanofuse from source (Go + mage)
#   - Build base microVM images (Docker + kernel)
#   - Run Firecracker microVMs (nested KVM)
#   - Test firewall rules, SPIRE, Vault, escape vectors
#   - Run full E2E test suite with sudo
#
# Designed to work from two locations:
#   1. nanofuse repo:  dev/vagrant/Vagrantfile  (NANOFUSE_ROOT = ../..)
#   2. standalone:     set NANOFUSE_SRC env var
#
# Usage:
#   vagrant up                    # provision + build + verify
#   vagrant ssh                   # interactive shell (full sudo)
#   vagrant ssh -c "sudo ..."    # run commands from host
#   vagrant destroy -f            # tear down and start fresh
#   vagrant provision             # re-run setup + verify without rebuild
#
# Firecracker requires /dev/kvm in the Linux guest. On macOS arm64,
# Parallels can only satisfy the closed loop when the host and provider expose
# nested virtualization to the guest. If Apple reports nested virtualization
# unsupported, this Vagrant environment is a client/API preflight only.

# Resolve nanofuse source: in-repo or external
SCRIPT_DIR = File.dirname(File.expand_path(__FILE__))
NANOFUSE_ROOT = if ENV["NANOFUSE_SRC"]
    ENV["NANOFUSE_SRC"]
  elsif File.exist?(File.join(SCRIPT_DIR, "..", "..", "go.mod"))
    File.expand_path(File.join(SCRIPT_DIR, "..", ".."))
  elsif File.exist?(File.join(SCRIPT_DIR, "..", "..", "nanofuse", "go.mod"))
    # Inside daax monorepo: dev/vagrant/ -> daax/nanofuse/
    File.expand_path(File.join(SCRIPT_DIR, "..", "..", "nanofuse"))
  else
    abort "Cannot find nanofuse source.\n" \
          "Either:\n" \
          "  - Place this at <nanofuse-repo>/dev/vagrant/Vagrantfile\n" \
          "  - Set NANOFUSE_SRC=/path/to/nanofuse\n"
  end

puts "nanofuse source: #{NANOFUSE_ROOT}"
PARALLELS_NESTED = ENV["NANOFUSE_PARALLELS_NESTED"] == "1" ? "on" : "off"
API_HOST_PORT = Integer(ENV.fetch("NANOFUSE_API_HOST_PORT", "18080"))

def apple_silicon_nested_virtualization_status
  return "not-darwin-arm64" unless RUBY_PLATFORM.include?("darwin") && `uname -m`.strip == "arm64"
  return "unknown" unless system("command -v swift >/dev/null 2>&1")

  output = `swift -e 'import Virtualization; print(VZGenericPlatformConfiguration.isNestedVirtualizationSupported)' 2>/dev/null`.strip
  return output if ["true", "false"].include?(output)

  "unknown"
end

APPLE_NESTED_STATUS = apple_silicon_nested_virtualization_status
if APPLE_NESTED_STATUS == "false" && PARALLELS_NESTED == "on"
  abort "Apple Virtualization reports nested virtualization unsupported on this macOS arm64 host.\n" \
        "Parallels cannot expose /dev/kvm here, so Firecracker closed-loop testing cannot run locally.\n" \
        "Unset NANOFUSE_PARALLELS_NESTED for client/API preflight only, or use a Linux/KVM host."
elsif APPLE_NESTED_STATUS == "false"
  STDERR.puts "Apple Virtualization reports nested virtualization unsupported on this macOS arm64 host; " \
              "Parallels will not expose /dev/kvm, so Firecracker closed-loop testing cannot pass locally."
end

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"
  config.vm.box_check_update = false
  config.vm.hostname = "nanofuse-dev"
  config.vm.boot_timeout = 300
  config.vm.network "forwarded_port",
    guest: 8080,
    host: API_HOST_PORT,
    host_ip: "127.0.0.1",
    auto_correct: true

  config.vm.provider "libvirt" do |lv|
    lv.cpus   = 4
    lv.memory = 4096
    lv.cpu_mode = "host-passthrough"   # nested KVM for Firecracker
    lv.nested = true
    lv.default_prefix = "nanofuse_"
  end

  config.vm.provider "parallels" do |prl|
    prl.cpus = 4
    prl.memory = 4096
    prl.customize "pre-boot", ["set", :id, "--nested-virt", PARALLELS_NESTED]
    prl.update_guest_tools = false
  end

  # Sync nanofuse source — exclude heavy/generated dirs
  # The images/base/build/ dir can be 2GB+, so exclude it entirely.
  # The vmlinux kernel (39MB) is synced separately if present.
  config.vm.synced_folder NANOFUSE_ROOT, "/nanofuse", type: "rsync",
    rsync__exclude: [
      ".git/",
      "bin/",
      "images/base/build/",
      "coverage.out",
      "coverage.html",
    ]

  # Sync this vagrant dir's scripts
  config.vm.synced_folder ".", "/vagrant-scripts", type: "rsync"

  # Provision: install deps + build nanofuse + build base image
  config.vm.provision "setup", type: "shell" do |s|
    s.path = "setup.sh"
    s.privileged = true
  end

  # Provision: verify everything works — fails vagrant up on failure
  config.vm.provision "verify", type: "shell" do |s|
    s.path = "verify.sh"
    s.privileged = true
  end
end
